{
  "cleanUrls": true,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/certificate", "dest": "/certificate.html" },
    { "src": "/myproject", "dest": "/MyProject.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
